# Copie este arquivo para ".env" (mesma pasta) e preencha com os dados
# do seu projeto Supabase. Veja o passo a passo no README.md.
#
# Onde encontrar: no painel do Supabase, vá em
# "Project Settings" > "API".
#
# VITE_SUPABASE_ANON_KEY é a chave pública do projeto: em projetos novos
# aparece como "Publishable key" (sb_publishable_...); em projetos mais
# antigos aparece como "anon" "public" (eyJ...). Nunca use a "Secret key"
# (sb_secret_...) nem a "service_role" aqui.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA-CHAVE-PUBLICA-AQUI

# ----------------------------------------------------------------------
# Tela de entrada do app: em vez de "criar conta", a usuária só digita um
# PIN. Por trás, o app usa esta ÚNICA conta fixa para conversar com o
# Supabase — você nunca precisa digitar esse e-mail/senha em lugar
# nenhum, só preencher aqui. Veja o README para o passo a passo completo.
#
# IMPORTANTE: para isso funcionar, vá em "Authentication" > "Settings"
# no Supabase e desative "Confirm email" — senão a conta fica esperando
# uma confirmação por e-mail que nunca vai chegar.
# ----------------------------------------------------------------------
VITE_APP_PIN=ESCOLHA-UM-PIN-AQUI
VITE_APP_EMAIL=SEU-EMAIL-AQUI
VITE_APP_PASSWORD=ESCOLHA-UMA-SENHA-INTERNA-QUALQUER
