# Copie este arquivo para ".env" (mesma pasta) e preencha com os dados
# do seu projeto Supabase. Veja o passo a passo no README.md.
#
# Onde encontrar: no painel do Supabase, vá em
# "Project Settings" > "API".
#
# VITE_SUPABASE_ANON_KEY é a chave pública do projeto: em projetos novos
# aparece como "Publishable key" (sb_publishable_...); em projetos mais
# antigos aparece como "anon" "public" (eyJ...). Nunca use a "Secret key"
# (sb_secret_...) nem a "service_role" aqui.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA-CHAVE-PUBLICA-AQUI
